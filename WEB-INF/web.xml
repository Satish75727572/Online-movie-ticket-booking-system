<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>Movie BookMyShow Clone</display-name>

    <welcome-file-list>
        <welcome-file>movies</welcome-file>
    </welcome-file-list>

    <!-- ======== SERVLET REGISTRATIONS ======== -->

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>LoginServlet</servlet-class>
        <!-- Load on startup to initialize database connection/tables -->
        <load-on-startup>1</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>MovieServlet</servlet-name>
        <servlet-class>MovieServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>MovieServlet</servlet-name>
        <url-pattern>/movies</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>SeatServlet</servlet-name>
        <servlet-class>SeatServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SeatServlet</servlet-name>
        <url-pattern>/seats</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>BookingServlet</servlet-name>
        <servlet-class>BookingServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>BookingServlet</servlet-name>
        <url-pattern>/book</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>HistoryServlet</servlet-name>
        <servlet-class>HistoryServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>HistoryServlet</servlet-name>
        <url-pattern>/my-bookings</url-pattern>
    </servlet-mapping>

    <!-- ======== ADMIN ADMIN SERVLETS ======== -->

    <servlet>
        <servlet-name>AdminLoginServlet</servlet-name>
        <servlet-class>AdminLoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminLoginServlet</servlet-name>
        <url-pattern>/admin-login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminMovieServlet</servlet-name>
        <servlet-class>AdminMovieServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminMovieServlet</servlet-name>
        <url-pattern>/admin-add-movie</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminBookingsServlet</servlet-name>
        <servlet-class>AdminBookingsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminBookingsServlet</servlet-name>
        <url-pattern>/admin-bookings</url-pattern>
    </servlet-mapping>

</web-app>